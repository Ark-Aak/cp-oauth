DATABASE_URL=postgresql://cpuser:cppass@db:5432/cpoauth
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-secret-change-in-production

# Optional: CDN base URL for Nuxt built assets (_nuxt)
NUXT_APP_CDN_URL=https://cdn.example.com/

# Optional: upload built static assets to S3-compatible object storage after npm run build
S3_UPLOAD_ENABLED=false
S3_REGION=oss-cn-hangzhou
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_SESSION_TOKEN=
S3_PREFIX=
S3_BUILD_DIR=.output/public
S3_UPLOAD_CONCURRENCY=8
S3_FORCE_PATH_STYLE=true

# Backward-compatible aliases also supported by script: OSS_*
